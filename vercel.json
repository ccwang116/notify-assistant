{
  "version": 2,
  "builds": [
    {
      "src": "./index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ],
  "crons": [
    {
      "path": "/daily/weather_tomorrow",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/daily/weather",
      "schedule": "0 23 * * *"
    }
  ]
}
